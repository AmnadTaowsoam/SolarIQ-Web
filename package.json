{
  "name": "solariq-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "generate:blog": "node scripts/generate-blog-data.mjs",
    "build": "npm run generate:blog && next build",
    "start": "next start",
    "lint": "eslint src instrumentation.ts --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src instrumentation.ts --ext .ts,.tsx --fix --max-warnings=0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky || true",
    "analyze": "ANALYZE=true npm run build",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@line/liff": "^2.27.3",
    "@react-google-maps/api": "^2.19.3",
    "@sentry/browser": "^10.47.0",
    "@sentry/nextjs": "^10.47.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.7",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "date-fns": "2.30.0",
    "firebase": "10.14.1",
    "lucide-react": "^0.294.0",
    "next": "^15.5.14",
    "next-intl": "^3.23.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^2.12.2",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "web-vitals": "^4.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@next/bundle-analyzer": "^15.5.14",
    "@playwright/test": "^1.42.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.14",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "next-pwa": "^5.6.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "lodash": "4.18.1",
    "rollup": "3.30.0",
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.5",
    "undici": "6.24.1",
    "@next/eslint-plugin-next": {
      "glob": "10.5.0"
    }
  }
}
