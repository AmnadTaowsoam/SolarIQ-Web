# ============================================
# SolarIQ-Web Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# 
# SECURITY NOTES:
# - NEXT_PUBLIC_* variables are embedded in the client bundle at build time
# - These are SAFE to expose because:
#   * Firebase API keys are designed to be public (security via Firebase Rules)
#   * Google Maps API keys should have HTTP referrer restrictions
# - NEVER put secrets, private keys, or passwords in NEXT_PUBLIC_* variables
# - Server-only secrets should use private env vars (no NEXT_PUBLIC_ prefix)
# ============================================

# API Configuration (required)
# The backend API URL - can be internal or public
NEXT_PUBLIC_API_URL=http://localhost:8080

# Firebase Configuration (required)
# These are PUBLIC identifiers, not secrets. Firebase security is enforced via:
# - Firebase Authentication rules
# - Firestore security rules
# - API quotas and domain restrictions
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id

# Google Maps API Key (optional — needed for map features in Solar Analysis)
# IMPORTANT: Restrict this key in Google Cloud Console:
# - Application restrictions: HTTP referrers
# - API restrictions: Only Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Emulator (optional — set to 'true' for local development with emulator)
# This is a feature flag, not sensitive data
NEXT_PUBLIC_USE_EMULATOR=false

# LIFF Configuration (required for LINE LIFF App)
# Get the LIFF ID from LINE Developers Console
# https://developers.line.biz/console/channel/{channel_id}/liff
NEXT_PUBLIC_LIFF_ID=your_liff_id_here

# White-label (optional)
# Default host suffix used to detect custom domains
NEXT_PUBLIC_DEFAULT_BRAND_SUFFIX=solariq.app

# ============================================
# Server-Only Variables (if needed in future)
# ============================================
# These should NOT have NEXT_PUBLIC_ prefix
# They will only be available in server-side code (API routes, getServerSideProps)
# Example:
# DATABASE_URL=postgresql://...
# STRIPE_SECRET_KEY=sk_...
# JWT_SECRET=...
