# WK-109: Performance Optimization - Cloudflare Pages Cache Headers
# https://developers.cloudflare.com/pages/configuration/headers/

# Static assets - Long cache (1 year)
/SolarIQ/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Images - Long cache (1 year)
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.png
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.webp
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.avif
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.svg
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
/*.ico
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Fonts - Long cache (1 year)
/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
/*.eot
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# JavaScript and CSS - Long cache (1 year)
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable

# Next.js static files - Long cache (1 year)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# API responses - Short cache (5 minutes)
/api/*
  Cache-Control: public, max-age=60, s-maxage=300

# HTML pages - Short cache (no cache)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
