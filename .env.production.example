# ============================================
# SolarIQ-Web Production Environment
# ============================================

# --- API ---
NEXT_PUBLIC_API_URL=https://api.solariqapp.com
NEXT_PUBLIC_API_BASE_URL=https://api.solariqapp.com/api/v1

# --- Firebase ---
NEXT_PUBLIC_FIREBASE_API_KEY=<your-firebase-api-key>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=solariq-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=solariq-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=solariq-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
NEXT_PUBLIC_FIREBASE_APP_ID=<app-id>

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<your-maps-api-key>

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=<your-sentry-dsn>
SENTRY_AUTH_TOKEN=<your-sentry-auth-token>

# --- App ---
NEXT_PUBLIC_APP_URL=https://app.solariqapp.com
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false
NEXTAUTH_URL=https://app.solariqapp.com
